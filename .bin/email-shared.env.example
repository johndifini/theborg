# ---------------------------------------------------------------------------
# email-shared.env — Gmail SMTP credentials for .bin/notify-email.sh
# (outbound batch-job notifications). THIS IS A TEMPLATE — values are fake.
# ---------------------------------------------------------------------------
# Copy it to the real location (outside the repo) and fill in your values:
#
#   mkdir -p ~/.claude/channels/email-shared
#   cp .bin/email-shared.env.example ~/.claude/channels/email-shared/.env
#   chmod 600 ~/.claude/channels/email-shared/.env
#   $EDITOR ~/.claude/channels/email-shared/.env
#
# EMAIL_SMTP_PASS must be a Gmail APP PASSWORD, not the account password.
# Create one at https://myaccount.google.com/apppasswords (requires 2FA on the
# sending account). The 16-char value's spaces are cosmetic — notify-email.sh
# strips all whitespace, so paste-with-spaces is fine.
#
# NEVER commit the filled-in .env. It lives under ~/.claude/ (outside the repo)
# by design, and `.env` is gitignored as a backstop. This .example — keys and
# docs, no real values — is the only version that belongs in version control.
#
# notify-email.sh parses KEY=VALUE line-by-line (it does NOT source this file),
# so do not put inline `# comments` after a value — they'd be read as part of it.
# ---------------------------------------------------------------------------

# Gmail address used to authenticate.
EMAIL_SMTP_USER=you@gmail.com

# Gmail App Password (16 chars). NOT your account login password.
EMAIL_SMTP_PASS=xxxxxxxxxxxxxxxx

# From address shown on the email. Defaults to EMAIL_SMTP_USER if omitted.
EMAIL_FROM=you@gmail.com

# Where notifications are delivered.
EMAIL_TO=recipient@example.com

# Optional — these are the defaults; uncomment only to override.
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
