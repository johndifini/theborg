# ──────────────────────────────────────────────────────────────
# The Borg — .gitignore
#
# Denylist style: most files are tracked by default; this file
# lists what to keep out. When you add a new kind of sensitive
# file, add a rule here BEFORE the first `git add`.
# Verify with:  git check-ignore -v <path>
# ──────────────────────────────────────────────────────────────

# ── OS / editor noise ────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# ── Backups & temp scratch ───────────────────────────────────
*_bak_*
*.bak
*.orig
.tmp.*
**/.tmp.*

# ── Log and state directories (anywhere in the tree) ───────────────────
**/logs/
**/log/
**/state/

# ── Secrets / local config ───────────────────────────────────
.env
.env.*
# …but committed *.example templates carry keys + docs, never values
# (e.g. .bin/email-shared.env.example). Re-allow them past the .env.* rule.
!**/.env.example
!**/*.env.example
*.pem
*.key
*_token*
*_secret*
**/.claude/settings.local.json
**/.claude/.credentials*

# Allow shared Claude settings, scheduled jobs, etc. — only the
# `*.local.json` variants and credential files are ignored above.

# ── Obsidian workspace state (per-machine) ───────────────────
.obsidian/
#**/.obsidian/workspace*
#**/.obsidian/cache
#**/.obsidian/plugins/*/data.json

# ── warren-bot-fett (financial / portfolio) ──────────────────
warren-bot-fett/PORTFOLIO.md

# ── mrs-beast (personal social identity) ─────────────────────
mrs-beast/.claude/commands/ai-week-image-prompt.md
mrs-beast/.claude/scheduled/mrs-beast-ai-week-image-prompt.prompt
mrs-beast/.bin/install-personal-tasks.sh

# ── cerebruh (second-brain content) ──────────────────────────
# Track structure + templates + the index, ignore actual notes.
cerebruh/ingest/*
!cerebruh/ingest/.gitkeep
cerebruh/wikis/*
!cerebruh/wikis/.gitkeep

# ── architetto (initialized product repos) ───────────────────
# Each repo under repos/ is its own independent git repo and is NOT
# part of The Borg's history. Track the directory's existence only.
repos/*
!repos/.gitkeep

# ── Generic catch-alls for accidental drops ──────────────────
*.sqlite
*.sqlite3
*.db
*.log
node_modules/
dist/
build/
__pycache__/
*.pyc
